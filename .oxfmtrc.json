{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "tabWidth": 2,
  "semi": true,
  "printWidth": 100,
  "singleQuote": false,
  "endOfLine": "lf",
  "trailingComma": "all",
  "experimentalSortImports": {},
  "ignorePatterns": [
    "pnpm-lock.yaml",
    "package-lock.json",
    "yarn.lock",
    "bun.lock",
    "pnpm-workspace.yaml",
    ".cache",
    ".output",
    "dist"
  ]
}
